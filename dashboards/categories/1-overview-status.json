{
  "title": "XRPL - 1. Overview & Status",
  "tags": [
    "xrpl",
    "overview"
  ],
  "timezone": "browser",
  "editable": true,
  "refresh": "5s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "title": "Validator State",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "xrpl_validator_state_value",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "color": "red",
                  "text": "Unknown"
                },
                "1": {
                  "color": "red",
                  "text": "Disconnected"
                },
                "2": {
                  "color": "yellow",
                  "text": "Connected"
                },
                "3": {
                  "color": "yellow",
                  "text": "Syncing"
                },
                "4": {
                  "color": "yellow",
                  "text": "Tracking"
                },
                "5": {
                  "color": "green",
                  "text": "Full"
                },
                "6": {
                  "color": "green",
                  "text": "Proposing"
                },
                "7": {
                  "color": "red",
                  "text": "Unreachable"
                }
              }
            }
          ]
        }
      }
    },
    {
      "title": "Current Ledger",
      "type": "stat",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "xrpl_ledger_sequence",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 0
        }
      }
    },
    {
      "title": "Validator Uptime",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "xrpl_validator_uptime_seconds",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "title": "Monitor Uptime",
      "type": "stat",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "xrpl_monitor_uptime_seconds",
          "refId": "A"
        }
      ],
      "options": {
        "colorMode": "value",
        "graphMode": "area"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "title": "Validation Agreement (24h)",
      "type": "gauge",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 8,
        "h": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "xrpl_validation_agreement_pct_24h",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "title": "Validation Agreement (1h)",
      "type": "gauge",
      "gridPos": {
        "x": 8,
        "y": 5,
        "w": 8,
        "h": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "xrpl_validation_agreement_pct_1h",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "title": "Ledger Age",
      "type": "stat",
      "gridPos": {
        "x": 16,
        "y": 5,
        "w": 4,
        "h": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "xrpl_ledger_age_seconds",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        }
      }
    },
    {
      "title": "Load Factor",
      "type": "gauge",
      "gridPos": {
        "x": 20,
        "y": 5,
        "w": 4,
        "h": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "xrpl_load_factor",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "min": 0,
          "max": 10
        }
      }
    }
  ],
  "schemaVersion": 38,
  "style": "dark",
  "version": 1
}