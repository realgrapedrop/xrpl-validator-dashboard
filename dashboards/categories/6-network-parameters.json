{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Select your Prometheus data source",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "8.0.0"
    }
  ],
  "title": "XRPL - 6. Network Parameters",
  "tags": [
    "xrpl",
    "parameters"
  ],
  "timezone": "browser",
  "editable": true,
  "refresh": "5s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "title": "Base Fee",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "xrpl_base_fee_xrp",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "XRP",
          "decimals": 6
        }
      }
    },
    {
      "title": "Reserve Base",
      "type": "stat",
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "xrpl_reserve_base_xrp",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "XRP"
        }
      }
    },
    {
      "title": "Reserve Increment",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "xrpl_reserve_inc_xrp",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "XRP"
        }
      }
    },
    {
      "title": "Validation Quorum",
      "type": "stat",
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 4
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "xrpl_validation_quorum",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Base Fee Over Time",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "xrpl_base_fee_xrp",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "XRP",
          "decimals": 6
        }
      }
    },
    {
      "title": "Load Factor Over Time",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 6
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "targets": [
        {
          "expr": "xrpl_load_factor",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 38,
  "style": "dark",
  "version": 1
}